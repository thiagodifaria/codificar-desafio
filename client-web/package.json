{
  "name": "codificar-chamados-web",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:types": "openapi-typescript ../service-api/openapi.yaml -o src/types/api.generated.ts",
    "test": "vitest run",
    "build": "npm run generate:types && vue-tsc -b && vite build",
    "typecheck": "vue-tsc -b",
    "preview": "vite preview"
  },
  "dependencies": {
    "@lucide/vue": "1.18.0",
    "vue": "3.5.38",
    "vue-router": "4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^26.1.0",
    "openapi-typescript": "7.13.0",
    "tailwindcss": "4.3.1",
    "typescript": "5.9.3",
    "vite": "8.0.16",
    "vitest": "^4.1.9",
    "vue-tsc": "3.3.4"
  },
  "overrides": {
    "js-yaml": "4.2.0"
  }
}
